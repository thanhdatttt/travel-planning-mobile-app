<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="30dp"
    android:background="#F9F7F2">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register"
            android:textColor="#000000"
            android:textSize="36sp"
            android:textStyle="bold"/>

        <!--    login button    -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/already_have_an_account_login"
            android:textSize="18sp"
            android:textColor="#555555" />

        <!--    Enter email    -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40sp"
            android:text="@string/enter_your_email"
            android:textStyle="bold"
            android:textSize="26sp"
            android:textColor="#000000" />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="10dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:autofillHints=""
            android:background="@drawable/edit_textbox"
            android:hint="@string/example_gmail_com"
            android:inputType="textEmailAddress" />
        <Button
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#F4C74F"
            android:text="@string/next"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View android:layout_width="0dp" android:layout_weight="1" android:layout_height="1dp" android:background="#000000" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/or" android:textSize="16sp"/>
            <View android:layout_width="0dp" android:layout_weight="1" android:layout_height="1dp" android:background="#000000" />
        </LinearLayout>

        <!--    social login    -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#d4372f"
            android:text="@string/continue_with_google"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#2b20f7"
            android:text="@string/continue_with_facebook"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
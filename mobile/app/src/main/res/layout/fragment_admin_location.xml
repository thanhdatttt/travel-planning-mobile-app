<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.admin.AdminLocationFragment">

    <!--HEADER-->
    <include android:id="@+id/adminHeader"
        layout="@layout/admin_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!--SEARCH AND FILTER-->
    <include android:id="@+id/searchAndFilter"
        layout="@layout/search_and_filter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!--LIST-->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLocations"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        tools:listitem="@layout/admin_item_location" />
</LinearLayout>
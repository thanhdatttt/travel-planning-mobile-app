<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="10dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back_button"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintBottom_toTopOf="@id/layoutButtons"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="@string/create_a_new_trip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="36sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <!--      Trip name      -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/trip_name"
                android:textColor="@color/text"
                android:textSize="26sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/edtTripName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="@color/black"
                android:autofillHints=""
                android:background="@drawable/edit_textbox"
                android:hint="@string/trip_to_ha_noi"
                android:textColorHint="@color/text_secondary"
                android:inputType="textEmailAddress" />

            <!--      start date      -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/start_date"
                android:textColor="@color/text"
                android:textSize="26sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/edtStartDate"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="@color/black"
                android:autofillHints=""
                android:drawableStart="@drawable/ic_calendar"
                android:drawablePadding="10dp"
                android:background="@drawable/edit_textbox"
                android:hint="@string/yyyy_mm_dd"
                android:textColorHint="@color/text_secondary"
                android:inputType="date" />

            <!--      end date      -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/end_date"
                android:textColor="@color/text"
                android:textSize="26sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/edtEndDate"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="@color/black"
                android:autofillHints=""
                android:drawableStart="@drawable/ic_calendar"
                android:drawablePadding="10dp"
                android:background="@drawable/edit_textbox"
                android:hint="@string/yyyy_mm_dd"
                android:textColorHint="@color/text_secondary"
                android:inputType="date" />
        </LinearLayout>
    </ScrollView>

    <!--      buttons      -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <!--       cancel         -->
        <com.google.android.material.button.MaterialButton
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="@string/cancel"
            android:textStyle="bold"
            android:textSize="16sp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!--       create         -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateTrip"
            android:text="@string/create_trip"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:textStyle="bold"
            android:textSize="16sp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/background">
    <!--  list of dates  -->
    <HorizontalScrollView
        android:id="@+id/dateScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="27 thg 5" android:layout_marginEnd="8dp" />
            <Button style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="28 thg 5" android:layout_marginEnd="8dp" />
            <Button style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="29 thg 5" />
        </LinearLayout>
    </HorizontalScrollView>
    <!-- locations of each date -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvItinerary"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:nestedScrollingEnabled="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dateScroll"
        tools:listitem="@layout/item_itinerary"/>

</androidx.constraintlayout.widget.ConstraintLayout>
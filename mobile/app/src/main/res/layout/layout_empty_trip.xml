<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="invisible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/your_trip_your_way"
            android:textColor="@color/text"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/plan_your_trip_by_your_ideas_or_use_ai_suggestions_to_get_recommendations"
            android:textColor="@color/text_secondary"
            android:textSize="20sp" />

        <!--    create and ai button    -->
        <Button
            android:id="@+id/btnCreateFirstTrip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/start_your_first_trip"
            android:textSize="20sp"
            android:layout_marginTop="20dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAi"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="8dp"
            android:text="@string/ai"
            android:textSize="20sp"
            android:textAllCaps="false"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_ai"
            app:iconPadding="8dp"
            app:iconGravity="textStart"
            app:iconTint="@color/primary" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
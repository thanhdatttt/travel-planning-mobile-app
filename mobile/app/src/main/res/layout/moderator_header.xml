<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/admin_header_gradient">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scaleX="1.1"
        android:scaleY="1.1"
        android:src="@drawable/admin_dots" />

    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:contentDescription="@string/back_button"
            android:padding="4dp"
            android:layout_marginLeft="16dp"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:tint="#000000" />

        <LinearLayout
            android:id="@+id/toggleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            app:checkedButton="@+id/btnUserMgt"
            app:layout_constraintTop_toBottomOf="@id/ivBack">

            <Button
                android:id="@+id/btnReview"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="3"
                android:background="@animator/admin_header_tab_bg"
                android:text="@string/reviews_Cap"
                android:textColor="@animator/admin_header_text_color"
                android:textStyle="bold"
                android:textSize="14sp"
                android:paddingHorizontal="15dp"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnLocations"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="3"
                android:background="@animator/admin_header_tab_bg"
                android:text="@string/locations"
                android:textColor="@animator/admin_header_text_color"
                android:textStyle="bold"
                android:textSize="14sp"
                android:paddingHorizontal="15dp"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnTrips"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="3"
                android:background="@animator/admin_header_tab_bg"
                android:text="@string/trips"
                android:textColor="@animator/admin_header_text_color"
                android:textStyle="bold"
                android:textSize="14sp"
                android:paddingHorizontal="15dp"
                app:backgroundTint="@null"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
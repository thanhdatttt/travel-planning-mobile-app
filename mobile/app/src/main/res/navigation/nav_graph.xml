<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.travelplanning.ui.mainscreen.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home"/>

    <fragment
        android:id="@+id/nav_review"
        android:name="com.example.travelplanning.ui.review.MyReviewFragment"
        android:label="MyReview"
        tools:layout="@layout/fragment_my_reviews"/>

    <fragment
        android:id="@+id/nav_account"
        android:name="com.example.travelplanning.ui.account.AccountFragment"
        android:label="Account"
        tools:layout="@layout/fragment_account" />

    <fragment
        android:id="@+id/nav_saved_locations"
        android:name="com.example.travelplanning.ui.bookmark.BookmarkFragment"
        android:label="Bookmarked"
        tools:layout="@layout/fragment_bookmark_list" />

    <fragment
        android:id="@+id/nav_favorite_trips"
        android:name="com.example.travelplanning.ui.favorite.FavoriteFragment"
        android:label="Favorite"
        tools:layout="@layout/fragment_favorite_list"/>

    <fragment
        android:id="@+id/nav_trip"
        android:name="com.example.travelplanning.ui.itinerary.TripContainerFragment"
        android:label="Trip"
        tools:layout="@layout/activity_trip" />

    <fragment
        android:id="@+id/nav_nearby"
        android:name="com.example.travelplanning.ui.map.NearbyFragment" android:label="Nearby"
        tools:layout="@layout/fragment_nearby" />

    <fragment
        android:id="@+id/nav_profile"
        android:name="com.example.travelplanning.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/nav_location_detail"
        android:name="com.example.travelplanning.ui.location_detail.LocationDetailFragment"
        android:label="Location Detail"
        tools:layout="@layout/fragment_location_detail">
        <argument
            android:name="location_id"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/nav_settings"
        android:name="com.example.travelplanning.ui.settings.SettingsFragment"
        android:label="App settings"
        tools:layout="@layout/fragment_profile"/>

    <fragment
        android:id="@+id/nav_trips"
        android:name="com.example.travelplanning.ui.itinerary.TripFragment"
        android:label="My Trips"
        tools:layout="@layout/fragment_trips" />

    <fragment
        android:id="@+id/nav_trip_detail"
        android:name="com.example.travelplanning.ui.itinerary.TripDetailFragment"
        android:label="Trip detail"
        tools:layout="@layout/fragment_trip_detail"/>

    <fragment
        android:id="@+id/nav_public_trip_detail"
        android:name="com.example.travelplanning.ui.itinerary.TripPublicDetailFragment"
        android:label="Trip detail"
        tools:layout="@layout/fragment_trip_public_detail"/>

    <fragment
        android:id="@+id/nav_chatbot"
        android:name="com.example.travelplanning.ui.chat.ChatbotFragment"
        android:label="TourGuide Bot"
        tools:layout="@layout/fragment_chatbot" />

    <fragment
        android:id="@+id/nav_admin"
        android:name="com.example.travelplanning.ui.admin.AdminUserFragment"
        android:label="fragment_admin_user"
        tools:layout="@layout/fragment_admin_user" />

    <fragment
        android:id="@+id/nav_admin_location"
        android:name="com.example.travelplanning.ui.admin.AdminLocationFragment"
        android:label="fragment_admin_location"
        tools:layout="@layout/fragment_admin_location" />

    <fragment
        android:id="@+id/nav_admin_stat"
        android:name="com.example.travelplanning.ui.admin.AdminStatFragment"
        android:label="fragment_admin_stat"
        tools:layout="@layout/fragment_admin_stat" />

    <fragment
        android:id="@+id/nav_trip_public_detail"
        android:name="com.example.travelplanning.ui.itinerary.TripPublicDetailFragment"
        android:label="Trip Detail">
    </fragment>

    <fragment
        android:id="@+id/nav_moderator_review"
        android:name="com.example.travelplanning.ui.moderator.ModeratorReviewFragment"
        android:label="ModeratorReviewFragment"
        tools:layout="@layout/fragment_moderator_review"/>

    <fragment
        android:id="@+id/nav_moderator_location"
        android:name="com.example.travelplanning.ui.moderator.ModeratorLocationFragment"
        android:label="ModeratorLocationFragment"
        tools:layout="@layout/fragment_moderator_location"/>

    <fragment
        android:id="@+id/nav_moderator_trip"
        android:name="com.example.travelplanning.ui.moderator.ModeratorTripFragment"
        android:label="ModeratorTripFragment"
        tools:layout="@layout/fragment_moderator_trip"/>

</navigation>
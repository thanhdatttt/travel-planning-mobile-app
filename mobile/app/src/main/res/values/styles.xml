<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ShapeAppearance.App.CircleComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">50%</item>
    </style>

    <style name="ChipStyle" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textSize">14sp</item>
        <item name="chipBackgroundColor">@color/white</item>
        <item name="chipIconTint">@animator/chip_stroke_selector</item>
        <item name="chipIconVisible">true</item>
        <item name="android:textColor">@animator/chip_stroke_selector</item>
        <item name="chipStrokeColor">@animator/chip_stroke_selector</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:checkable">true</item>
        <item name="chipCornerRadius">100dp</item>
        <item name="chipEndPadding">7dp</item>
        <item name="chipStartPadding">7dp</item>
        <item name="android:strokeWidth">2</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:paddingLeft">2dp</item>
    </style>

    <style name="CustomDropdownLayoutInner" parent="Widget.AppCompat.AutoCompleteTextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">35dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:background">@null</item>
        <item name="android:inputType">none</item>
        <item name="android:focusable">false</item>
        <item name="android:cursorVisible">false</item>
    </style>

    <style name="CustomDropdownLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeColor">#CCCCCC</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="android:textColorHint">#555555</item>
        <item name="boxCornerRadiusTopStart">5dp</item>
        <item name="boxCornerRadiusTopEnd">5dp</item>
        <item name="boxCornerRadiusBottomStart">5dp</item>
        <item name="boxCornerRadiusBottomEnd">5dp</item>
    </style>

    <style name="AdminStatText" parent="android:Widget.TextView">

    </style>
    <style name="BottomSheetDialogTheme" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
    <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet">
        <item name="android:background">@color/background</item>
    </style>
    <style name="ShapeAppearanceOverlay.Material3.Corner.Small" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    <style name="MaterialAlertDialog_Warning" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/design_default_color_error</item>
    </style>

    <style name="InfoRowStyle">
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="AdminInfoRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingVertical">8dp</item>
    </style>

    <style name="AdminInfoLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="AdminInfoValue">
        <item name="android:layout_width">200dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">end</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="AdminEditInfoValue" parent="android:Widget.EditText">
        <item name="android:layout_width">180dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/edit_textbox</item>
        <item name="android:paddingHorizontal">10dp</item>
        <item name="android:paddingVertical">10dp</item>>
        <item name="android:gravity">end</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <style name="WhiteDialog" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="android:backgroundTint">@color/white</item>
    </style>

    <style name="AdminStatLabel" parent="android:Widget.TextView">
        <item name="android:background">@drawable/admin_stat_background</item>
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:strokeWidth">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#000000</item>
    </style>
</resources>